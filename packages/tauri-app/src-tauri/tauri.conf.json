{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "UniversalAI Agent",
  "version": "0.1.0",
  "identifier": "com.universalai.agent-desktop",
  "build": {
    "beforeBuildCommand": "pnpm build",
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "UniversalAI Agent",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https: wss:; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "publisher": "Mr-YeYuanYu",
    "homepage": "https://github.com/Mr-YeYuanYu/universalai-agent-desktop",
    "shortDescription": "AI-powered API Agent Desktop Application",
    "longDescription": "A desktop application that uses AI to help users interact with APIs through natural language conversation"
  }
}
